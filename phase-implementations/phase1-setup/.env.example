# ============================================
# ENVIRONMENT VARIABLES CONFIGURATION
# ============================================
# Ye file ko .env mein rename karo aur values fill karo
# NEVER commit .env file to git (add to .gitignore)

# SERVER PORT
# Server kis port par chalega
# http://localhost:5000 par access ho sakta hai
PORT=5000

# MONGODB CONNECTION
# Local MongoDB: mongodb://localhost:27017/mobile-app-db
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
# Explanation:
# - mongodb:// = Protocol (database connection ka standard)
# - localhost:27017 = Local machine, MongoDB default port
# - mobile-app-db = Database name (apna choose karo)
MONGODB_URI=mongodb://localhost:27017/mobile-app-db

# NODE ENVIRONMENT
# development = Local testing (detailed errors dikhao)
# production = Live server (hide sensitive errors)
NODE_ENV=development

# JWT SECRET KEY
# Token ko encrypt karne ke liye secret key
# Minimum 32 characters, complex string (numbers, letters, symbols)
# Agar leak ho toh hacker tokens ban sakte hain
# Production mein random, long string use karo
JWT_SECRET=your_super_secret_key_min_32_chars_long_with_numbers_123456789

# JWT TOKEN EXPIRY
# Token kitne time tak valid rahega
# Examples: 7d (7 days), 24h (24 hours), 30m (30 minutes)
JWT_EXPIRE=7d

# BCRYPT ROUNDS
# Password encryption ki strength
# 10 = Good balance between security aur speed
# Zyada rounds = zyada secure lekin slow password hashing
BCRYPT_ROUNDS=10

# CORS ALLOWED ORIGINS
# Mobile app URL jo requests kar sakte hain
# Multiple origins: http://localhost:3000,http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# DATABASE
# Username aur password agar MongoDB atlas use kar rahe ho
MONGO_USERNAME=your_username
MONGO_PASSWORD=your_password
